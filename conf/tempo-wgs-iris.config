//
// These should just be the options that do
// _not_ depend on the cluster but the which
// pipeline we are running: wes vs wgs
//
// WGS specific options
//
// This one is hard coded with IRIS specific limits
//

params {
    max_records_in_ram = "5000000"
}

//
// Tiered queue/time picker.
//
// `ladder` is a list of [queue: <str>, time: <Duration>] maps, ordered
// from shortest tier to longest. Behavior per task.attempt:
//   attempt 1                  -> ladder[0]
//   retry, prev hit walltime   -> step one tier up (clamped to last)
//   retry, prev was non-wall   -> stay in current tier
//
// "Walltime hit" = previous run took >= (prev tier's time - 5min).
// task.previousTrace.realtime is ms (Nextflow 25.x); null/missing is
// treated as MAX to force escalation defensively.
//
def safetyMs = 5 * 60 * 1000

def tierFor = { task, ladder ->
    if ( task.attempt == 1 ) return 0
    def prevIdx   = Math.min( task.attempt - 2, ladder.size() - 1 )
    def prevCapMs = ladder[prevIdx].time.toMillis()
    def realMs    = (task.previousTrace?.realtime ?: Long.MAX_VALUE)
    def hitWall   = realMs >= (prevCapMs - safetyMs)
    def idx       = hitWall ? prevIdx + 1 : prevIdx
    return Math.min( idx, ladder.size() - 1 )
}

def queueFor = { task, ladder -> ladder[ tierFor(task, ladder) ].queue }
def timeFor  = { task, ladder -> ladder[ tierFor(task, ladder) ].time  }

def shortMediumLongLadder = [
    [queue: 'cpushort,cmobic_short', time: 2.h  ],
    [queue: 'cmobic_short',          time: 3.h  ],
    [queue: 'cmobic_cpu',            time: 167.h],
]

process {

  //
  // Attempt 1: submit to short queues (2h cap fits both cpushort=2h and
  // cmobic_short=3h). On retry: if the previous attempt ran < 1h55m
  // (6_900_000 ms), it almost certainly did NOT hit the 2h wall-time
  // limit (failure was OOM / transient / etc.), so stay in the short
  // queues with another 2h request. Otherwise escalate to the long
  // queue cmobic_cpu with the original time ramp (shifted one attempt
  // to the left).
  //
  // task.previousTrace.realtime is a long in milliseconds (Nextflow 25.x);
  // null on attempt 1, defensively treated as MAX on a missing-trace retry.
  //
  queue = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 'cpushort,cmobic_short' : 'cmobic_cpu' }
  time  = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 48.h * (task.attempt - 1) : 167.h) }

  withName:CrossValidateSamples {
    cpus = { 2 }
    memory = { 1.GB }
    executor = 'local'
  }
  withName:SplitLanesR1 {
    cpus = { 2 }
    memory = { 1.GB }
  }
  withName:SplitLanesR2 {
    cpus = { 2 }
    memory = { 1.GB }
  }
  //
  // AlignReads: use the short/medium/long ladder so a walltime hit steps
  // tier-by-tier (2h -> 3h -> 167h) rather than jumping straight to the
  // long queue. See queueFor / timeFor and shortMediumLongLadder at the
  // top of this file. CPU formula stays WGS-specific (16 + 8 * attempt);
  // WGS alignment is heavier than WES, so the WES 4 + 4 reduction is not
  // ported here.
  //
  withName:AlignReads {
    cpus   = { 16 + 8 * task.attempt }
    memory = { 15.GB }
    queue  = { queueFor(task, shortMediumLongLadder) }
    time   = { timeFor (task, shortMediumLongLadder) }
  }
  withName:GATK4SPARK_MARKDUPLICATES {
    cpus = { 16 }
    memory = { (4.GB + (task.attempt).GB) * task.cpus }
  }
  withName:GATK4SPARK_SETNMMDANDUQTAGS {
    cpus = { 4 }
    memory = { (2.GB + (task.attempt).GB) * task.cpus }
  }
  withName:BQSR_SPLITINTERVALS {
    cpus = { 2 }
    memory = { (1.GB + (task.attempt).GB) * task.cpus }
  }
  withName:GATK4SPARK_BASERECALIBRATOR {
    cpus = { 4 }
    memory = { (8.GB + (task.attempt).GB) * task.cpus }
  }
  withName:GATK4_GATHERBQSRREPORTS {
    cpus = { 4 }
    memory = { (2.GB + (task.attempt).GB) * task.cpus }
  }
  withName:GATK4SPARK_APPLYBQSR {
    cpus = { 8 }
    memory = { (8.GB + (task.attempt).GB) * task.cpus }
  }
  withName:'MERGE_SETTAGS_BAM|MERGE_BQSR_BAM' {
    cpus = { 8 }
    memory = { (2.GB + (task.attempt).GB) * task.cpus }
  }
  withName:'INDEX_SETTAGS_BAM|INDEX_BQSR_BAM' {
    cpus = { 8 }
    memory = { (2.GB + (task.attempt).GB) * task.cpus }
  }
  withName:CreateScatteredIntervals {
    cpus = { 2 }
    memory = { (1.GB * task.attempt) * task.cpus }
  }

  // RunMutect2 is hard coded to take 8Gb in `-Xmx8g`
  // 1 cpu for mutect and and 1 for singularity
  //
  // Also add some resources on subsequent attempts
  // to help if the program is congestion
  //
  withName:RunMutect2 {
    cpus = { 2 + 1 * task.attempt }
    memory = { 10.GB + 5.GB * task.attempt }
  }
  
  withName:SomaticCombineMutect2Vcf {
    cpus = { 1 + 1 * task.attempt }
    memory = { 2.GB + 2.GB * task.attempt }
  }

  withLabel:multiqc_process { // SampleRunMultiQC , SomaticRunMultiQC , CohortRunMultiQC
    cpus = { 4 + 12 * task.attempt }
    memory = { 34.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: SomaticRunSVclone {
    cpus = { 4 + 12 * task.attempt }
    memory = { 34.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName:SomaticAnnotateMaf {
    cpus = { 4 + 12 * task.attempt }
    memory = { 34.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName:SomaticFacetsAnnotation {
    cpus = { 4 + 12 * task.attempt }
    memory = { 34.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName:RunPolysolver {
    cpus = { 8 }
    memory = { 16.GB * task.attempt }
  }

  withName:QcQualimap {
    cpus = { task.attempt<=2 ? 4 : 8 }
    memory = { 20.GB } // N.B. Tempo multiples mem by cpu's for this process

    // Calculate what TEMPO actually uses
    clusterOptions = {
      def requestedMem = task.cpus * task.memory.toGiga() * 1.1  // Add 10% buffer
      "--mem=${requestedMem.intValue()}G"
    }

  }


  //
  // SvABA appears to be supper parallel
  // 1561% with 16cpus, try more
  //
  // Just give it the max time, do not want to
  // kill and restart long jobs

  withName: '.*RunSvABA' {
    cpus = { task.attempt <= 2 ? 8 : 16 }
    memory = { task.attempt <= 2 ? 16.Gb : 32.Gb }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : 167.h }
  }

  withName:RunLOHHLA {
    cpus = { 4 + 12 * task.attempt }
    memory = { 34.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 6.h * (task.attempt - 1) : 24.h) }
  }

  //
  // Delly takes forever but uses very little
  // resources (probably why it takes forever)
  // so max out on time
  // It seems to need lots of memory so correct
  // for that.
  // Just give it the max time

  withName: SomaticDellyCall {
    cpus = { task.attempt <=2 ? 2 : 4 }
    memory = { task.attempt <=2 ? 16.Gb : 32.Gb }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : 167.h }
  }

  withName: GermlineDellyCall {
    cpus = { 2 + 1 * task.attempt }
    memory = { 160.GB * task.attempt } // 160, 320, 480, 640
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 55.h * (task.attempt - 1) : 167.h) }
  }

  //
  // Same with Neoantigen
  //
  withName: RunNeoantigen {
    cpus = { 4 * task.attempt }
    memory = { 160.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : 167.h }
  }

  //
  // Default SLURM config
  //


  withName: 'runBRASS.+' {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: runBRASS {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: SomaticRunManta {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: GermlineRunManta {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: SomaticRunStrelka2 {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: GermlineRunStrelka2 {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: SomaticCombineChannel {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: GermlineCombineChannel {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: RunMsiSensor {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: RunMutationSignatures {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: MetaDataParser {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: HRDetect {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: CohortRunMultiQC {
    cpus = { 4 + 12 * task.attempt } // 16,28,40,52
    memory = { 246.GB * task.attempt }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

  withName: DoFacets {
    cpus = { task.attempt <= 2 ? 2 : 4 }
    memory = { task.attempt <= 2 ? 64.GB : 128.GB }
    time = { ( task.attempt == 1 || (task.previousTrace?.realtime ?: Long.MAX_VALUE) < 6_900_000 ) ? 2.h : (task.attempt < 4 ? 30.h * (task.attempt - 1) : 167.h) }
  }

}
